# Stack: Cursor -> GitHub -> Vercel + Supabase
# Copie para .env.local no Cursor (dev) e configure no Vercel (producao)

# IMPORTANTE: use a URL do Supabase (.supabase.co), NAO a URL da Vercel
NEXT_PUBLIC_SUPABASE_URL=https://goppveejenbsedapffpp.supabase.co
# Supabase → Project Settings → API Keys → "anon" "public" (copie a chave inteira, começa com eyJ)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Producao (Vercel): OBRIGATORIO — links de e-mail usam esta URL
NEXT_PUBLIC_SITE_URL=https://dash-financas-delta.vercel.app
# Dev local: NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth: cadastro em /login (Criar conta), tabela "senha" e ambiente isolado por usuario (RLS).
# Recuperacao e confirmacao de e-mail — Supabase Authentication -> URL Configuration:
# Site URL: https://dash-financas-delta.vercel.app  (NAO use localhost em producao)
# Redirect URLs (Authentication -> URL Configuration):
#   https://dash-financas-delta.vercel.app/auth/callback
#   https://dash-financas-delta.vercel.app/auth/verificado
#   https://dash-financas-delta.vercel.app/login/redefinir-senha
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/verificado
#   http://localhost:3000/login/redefinir-senha

# Migrations obrigatorias no Supabase SQL Editor (nessa ordem):
# 1) 20260531120000_multi_user_senha.sql
# 2) 20260601120000_auth_user_setup_trigger.sql
# 3) 20260602120000_enforce_multi_user_isolation.sql
